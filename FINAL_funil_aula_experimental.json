        "jsCode": "const prospect = $node['Buscar dados do prospect'].json;\nconst data = Array.isArray(prospect) ? prospect[0] : prospect;\n\nconst uuid = 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {\n  const r = Math.random() * 16 | 0;\n  const v = c === 'x' ? r : (r & 0x3 | 0x8);\n  return v.toString(16);\n});\n\nconst numero = '55' + data.cellphone;\nconst nome = data.firstName.charAt(0).toUpperCase() + data.firstName.slice(1).toLowerCase();\n\nreturn [{\n  json: {\n    session_id: uuid,\n    cellphone: data.cellphone,\n    numero_formatado: numero,\n    firstName: nome,\n    payload_evo: JSON.stringify({\n      number: numero,\n      text: 'Olá, ' + nome + '! 👋 Que bom ter você aqui hoje! Como foi sua experiência na aula experimental? Conta pra mim 😊',\n      delay: 0\n    })\n  }\n}];"
