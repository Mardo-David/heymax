      {
        "parameters": {
          "jsCode": "// Extrai texto da resposta e phone do prospect (se enviado no body)\n// NOTA: Se phone não vier no POST, a busca no banco pega a sessão parcial mais recente\n// DÉBITO TÉCNICO: com múltiplos prospects simultâneos, a busca sem phone pode retornar sessão errada\nconst body = $json.body || {};\nconst text = body.message || body.text || '';\nconst phone = body.phone || '';\n\nreturn {\n  json: {\n    text: text,\n    phone: phone\n  }\n};",
          "mode": "runOnceForEachItem"
        },
